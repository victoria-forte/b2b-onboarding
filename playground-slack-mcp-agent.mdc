LOG_FILE=$(find ~/Library/Application\ Support/Cursor/logs -name "*playground-slack-mcp*.log" -type f 2>/dev/null | xargs -I {} stat -f "%m %N" {} 2>/dev/null | sort -rn | head -1 | cut -d' ' -f2-) && \
if [ -n "$LOG_FILE" ]; then \
