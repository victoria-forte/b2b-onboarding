[ -f /usr/local/bin/node ] && NODES_FOUND=$((NODES_FOUND+1)) && echo "Found: Direct install"

if [ $NODES_FOUND -gt 1 ]; then
  echo ""
  echo "🟠 Multiple Node installations detected: $NODES_FOUND total"
  echo "   Recommendation: Clean uninstall all + fresh NVM install"
fi
```

