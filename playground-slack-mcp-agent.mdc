**Clean Reinstall Procedure:**

```bash
echo "🔧 Starting Clean Node.js Reinstall (Shopify Recommended Method)"
echo ""
echo "Step 1: Backing up current configuration..."

# Backup .zshrc just in case
cp ~/.zshrc ~/.zshrc.backup-$(date +%Y%m%d)
echo "✅ Backed up .zshrc"

echo ""
echo "Step 2: Uninstalling all Node.js installations..."

# 2a. Remove NVM
if [ -d ~/.nvm ]; then
  echo "  Removing NVM directory..."
  rm -rf ~/.nvm
  echo "  ✅ NVM directory removed"
fi

# 2b. Remove NVM from .zshrc
if grep -q "NVM_DIR" ~/.zshrc 2>/dev/null; then
  echo "  Removing NVM configuration from .zshrc..."
  sed -i '' '/NVM_DIR/d' ~/.zshrc
  sed -i '' '/nvm\.sh/d' ~/.zshrc
  sed -i '' '/bash_completion.*nvm/d' ~/.zshrc
  echo "  ✅ NVM configuration removed from .zshrc"
fi

# 2c. Unlink Homebrew Node (if present)
if command -v brew &> /dev/null; then
  echo "  Unlinking Homebrew Node..."
  brew unlink node 2>/dev/null && echo "  ✅ Homebrew Node unlinked" || echo "  (No Homebrew Node found)"
fi

# 2d. Remove direct Node installations (if present)
if [ -f /usr/local/bin/node ]; then
  echo "  Removing direct Node installation..."
  sudo rm -f /usr/local/bin/node /usr/local/bin/npm /usr/local/bin/npx
  echo "  ✅ Direct Node installation removed"
fi

echo ""
echo "Step 3: Verifying Node is completely removed..."
if command -v node &> /dev/null; then
  echo "  ⚠️  Node still detected at: $(which node)"
  echo "  Manual cleanup may be needed"
else
  echo "  ✅ Node successfully removed"
fi

echo ""
echo "Step 4: Installing fresh NVM..."
curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.7/install.sh | bash

echo ""
echo "Step 5: Configuring .zshrc..."
# NVM installer should do this, but verify
if ! grep -q "NVM_DIR" ~/.zshrc; then
  echo 'export NVM_DIR="$HOME/.nvm"' >> ~/.zshrc
  echo '[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm' >> ~/.zshrc
  echo '[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion' >> ~/.zshrc
  echo "✅ Added NVM configuration to .zshrc"
else
  echo "✅ NVM already configured in .zshrc"
fi

echo ""
echo "Step 6: Reloading shell configuration..."
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

echo ""
echo "Step 7: Installing Node.js 20 (LTS - Shopify recommended)..."
nvm install 20

echo ""
echo "Step 8: Setting Node 20 as default..."
nvm use 20
nvm alias default 20

echo ""
echo "Step 9: Verification..."
echo "  Node version: $(node --version)"
echo "  NPX version: $(npx --version)"
echo "  Node location: $(which node)"
echo "  NPX location: $(which npx)"

if [[ "$(which node)" == *".nvm"* ]]; then
  echo ""
  echo "✅ Clean reinstall successful!"
  echo ""
  echo "📋 Summary:"
  echo "  - Removed all conflicting Node installations"
  echo "  - Installed fresh NVM"
  echo "  - Installed Node v20 (matches Shopify dev environment)"
  echo "  - Configured .zshrc correctly"
  echo ""
  echo "🔄 NEXT STEP: Fully restart Cursor (Cmd+Q and reopen)"
  echo "   This is REQUIRED for Cursor to pick up the new Node installation"
else
  echo ""
  echo "⚠️  Warning: Node not detected from NVM"
  echo "   This may require a shell restart: source ~/.zshrc"
fi
```

