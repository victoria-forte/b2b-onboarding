cat ~/.cursor/mcp.json | python3 -c "import sys,json,re; auth=json.load(sys.stdin).get('mcpServers',{}).get('vault-mcp',{}).get('headers',{}).get('Authorization',''); token=auth.replace('Bearer ',''); print('✅ Valid UUID format' if re.match(r'^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$', token) else '❌ Invalid UUID format')"

